# Normalize line endings to LF in the repository (silences CRLF warnings on Windows
# checkouts while keeping a consistent representation in history).
* text=auto eol=lf

*.rs    text eol=lf
*.ts    text eol=lf
*.js    text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf

# Binary assets — never normalize.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.bos   binary
